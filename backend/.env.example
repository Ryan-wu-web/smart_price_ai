# 火山引擎配置（必填）
VOLCENGINE_API_KEY=your-api-key-here
VOLCENGINE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
VOLCENGINE_MODEL=your-endpoint-id-here

# 数据库配置（可选，默认使用内存 Mock 数据）
DATABASE_URL=postgresql://user:password@localhost:5432/smartprice
REDIS_URL=redis://localhost:6379/0

# 调试模式（生产环境设为 false）
DEBUG=false
