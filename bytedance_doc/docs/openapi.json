{
  "openapi": "3.1.0",
  "info": {
    "title": "Smart Price API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/recognize": {
      "post": {
        "tags": [
          "recognize"
        ],
        "summary": "Recognize",
        "operationId": "recognize_api_v1_recognize_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecognizeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecognizeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/recognize/multi": {
      "post": {
        "tags": [
          "recognize"
        ],
        "summary": "Recognize Multi",
        "operationId": "recognize_multi_api_v1_recognize_multi_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecognizeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecognizeMultiResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/suggest": {
      "get": {
        "tags": [
          "suggest"
        ],
        "summary": "Suggest",
        "operationId": "suggest_api_v1_suggest_get",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "商品品类",
              "title": "Category"
            },
            "description": "商品品类"
          },
          {
            "name": "brand",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "品牌",
              "default": "",
              "title": "Brand"
            },
            "description": "品牌"
          },
          {
            "name": "color",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "颜色",
              "default": "",
              "title": "Color"
            },
            "description": "颜色"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuggestResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/compare": {
      "get": {
        "tags": [
          "compare"
        ],
        "summary": "Compare",
        "operationId": "compare_api_v1_compare_get",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Category"
            }
          },
          {
            "name": "brand",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Brand"
            }
          },
          {
            "name": "color",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Color"
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Sort By"
            }
          },
          {
            "name": "filter_mode",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Filter Mode"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompareResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/filter": {
      "post": {
        "tags": [
          "filter"
        ],
        "summary": "Filter",
        "operationId": "filter_api_v1_filter_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FilterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FilterResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/trend/{product_id}": {
      "get": {
        "tags": [
          "trend"
        ],
        "summary": "Trend",
        "operationId": "trend_api_v1_trend__product_id__get",
        "parameters": [
          {
            "name": "product_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Product Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrendResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/report": {
      "post": {
        "tags": [
          "report"
        ],
        "summary": "Report",
        "operationId": "report_api_v1_report_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/chat": {
      "post": {
        "tags": [
          "chat"
        ],
        "summary": "Chat",
        "operationId": "chat_api_v1_chat_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/chat/stream": {
      "post": {
        "tags": [
          "chat"
        ],
        "summary": "Chat Stream",
        "description": "SSE 流式聊天：逐字返回 AI 回复。",
        "operationId": "chat_stream_api_v1_chat_stream_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChatRequest": {
        "properties": {
          "message": {
            "type": "string",
            "maxLength": 4000,
            "minLength": 1,
            "title": "Message"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id"
          },
          "current_product": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Current Product"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "ChatRequest"
      },
      "ChatResponse": {
        "properties": {
          "reply": {
            "type": "string",
            "title": "Reply"
          },
          "action": {
            "type": "string",
            "title": "Action",
            "default": "none"
          },
          "action_data": {
            "additionalProperties": true,
            "type": "object",
            "title": "Action Data"
          },
          "session_id": {
            "type": "string",
            "title": "Session Id"
          }
        },
        "type": "object",
        "required": [
          "reply",
          "session_id"
        ],
        "title": "ChatResponse"
      },
      "CompareResponse": {
        "properties": {
          "products": {
            "items": {
              "$ref": "#/components/schemas/ProductResponse"
            },
            "type": "array",
            "title": "Products"
          }
        },
        "type": "object",
        "required": [
          "products"
        ],
        "title": "CompareResponse"
      },
      "FilterRequest": {
        "properties": {
          "query_text": {
            "type": "string",
            "minLength": 1,
            "title": "Query Text",
            "description": "自然语言筛选条件"
          }
        },
        "type": "object",
        "required": [
          "query_text"
        ],
        "title": "FilterRequest"
      },
      "FilterResponse": {
        "properties": {
          "filters": {
            "additionalProperties": true,
            "type": "object",
            "title": "Filters",
            "description": "解析后的筛选条件"
          }
        },
        "type": "object",
        "required": [
          "filters"
        ],
        "title": "FilterResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ProductResponse": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "brand": {
            "type": "string",
            "title": "Brand"
          },
          "category": {
            "type": "string",
            "title": "Category"
          },
          "color": {
            "type": "string",
            "title": "Color"
          },
          "price": {
            "type": "number",
            "minimum": 0.0,
            "title": "Price"
          },
          "platform": {
            "type": "string",
            "title": "Platform"
          },
          "rating": {
            "type": "number",
            "maximum": 5.0,
            "minimum": 0.0,
            "title": "Rating",
            "default": 0.0
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tags"
          },
          "original_price": {
            "type": "number",
            "minimum": 0.0,
            "title": "Original Price",
            "default": 0.0
          },
          "image_url": {
            "type": "string",
            "title": "Image Url",
            "default": ""
          },
          "id": {
            "type": "string",
            "title": "Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "name",
          "brand",
          "category",
          "color",
          "price",
          "platform",
          "id"
        ],
        "title": "ProductResponse"
      },
      "RecognizeMultiResponse": {
        "properties": {
          "objects": {
            "items": {
              "$ref": "#/components/schemas/RecognizedObject"
            },
            "type": "array",
            "title": "Objects"
          }
        },
        "type": "object",
        "required": [
          "objects"
        ],
        "title": "RecognizeMultiResponse"
      },
      "RecognizeRequest": {
        "properties": {
          "image_base64": {
            "type": "string",
            "maxLength": 15000000,
            "minLength": 1,
            "title": "Image Base64",
            "description": "Base64 编码的商品图片"
          }
        },
        "type": "object",
        "required": [
          "image_base64"
        ],
        "title": "RecognizeRequest"
      },
      "RecognizeResponse": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "description": "商品名称"
          },
          "brand": {
            "type": "string",
            "title": "Brand",
            "description": "品牌",
            "default": ""
          },
          "category": {
            "type": "string",
            "title": "Category",
            "description": "品类"
          },
          "color": {
            "type": "string",
            "title": "Color",
            "description": "颜色",
            "default": ""
          },
          "material": {
            "type": "string",
            "title": "Material",
            "description": "材质",
            "default": ""
          },
          "style": {
            "type": "string",
            "title": "Style",
            "description": "款式",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "name",
          "category"
        ],
        "title": "RecognizeResponse"
      },
      "RecognizedObject": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "brand": {
            "type": "string",
            "title": "Brand",
            "default": ""
          },
          "category": {
            "type": "string",
            "title": "Category"
          },
          "color": {
            "type": "string",
            "title": "Color",
            "default": ""
          },
          "center": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Center"
          }
        },
        "type": "object",
        "required": [
          "name",
          "category"
        ],
        "title": "RecognizedObject"
      },
      "ReportRequest": {
        "properties": {
          "product_name": {
            "type": "string",
            "title": "Product Name"
          },
          "best_choice": {
            "additionalProperties": true,
            "type": "object",
            "title": "Best Choice"
          },
          "alternatives": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Alternatives"
          }
        },
        "type": "object",
        "required": [
          "product_name",
          "best_choice"
        ],
        "title": "ReportRequest"
      },
      "ReportResponse": {
        "properties": {
          "summary": {
            "type": "string",
            "title": "Summary"
          },
          "pros": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Pros"
          },
          "cons": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Cons"
          },
          "recommendation": {
            "type": "string",
            "title": "Recommendation"
          }
        },
        "type": "object",
        "required": [
          "summary",
          "pros",
          "cons",
          "recommendation"
        ],
        "title": "ReportResponse"
      },
      "SuggestResponse": {
        "properties": {
          "cards": {
            "items": {
              "$ref": "#/components/schemas/SuggestionCard"
            },
            "type": "array",
            "title": "Cards",
            "description": "建议卡片列表"
          }
        },
        "type": "object",
        "required": [
          "cards"
        ],
        "title": "SuggestResponse"
      },
      "SuggestionCard": {
        "properties": {
          "type": {
            "type": "string",
            "title": "Type",
            "description": "卡片类型"
          },
          "title": {
            "type": "string",
            "title": "Title",
            "description": "卡片标题"
          },
          "description": {
            "type": "string",
            "title": "Description",
            "description": "卡片描述"
          }
        },
        "type": "object",
        "required": [
          "type",
          "title",
          "description"
        ],
        "title": "SuggestionCard"
      },
      "TrendResponse": {
        "properties": {
          "trend": {
            "type": "string",
            "title": "Trend",
            "description": "趋势描述"
          },
          "advice": {
            "type": "string",
            "title": "Advice",
            "description": "购买建议"
          },
          "confidence": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence",
            "description": "置信度"
          },
          "history_prices": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "History Prices",
            "description": "历史价格数据，每项含 date/price/platform"
          }
        },
        "type": "object",
        "required": [
          "trend",
          "advice",
          "confidence"
        ],
        "title": "TrendResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
